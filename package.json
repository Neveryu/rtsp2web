{
  "name": "rtsp2web",
  "version": "1.0.0",
  "description": "在web页面中直接播放rtsp视频流",
  "keywords": [
    "rtsp",
    "media source extensions",
    "ffmpeg",
    "socket.io"
  ],
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "pm2 start example/index.js --name rtsp",
    "stop": "pm2 stop rtsp",
    "delete": "pm2 delete rtsp",
    "restart": "npm stop && npm run delete && npm start",
    "node": "node example/index.js",
    "stop-all": "pm2 stop all",
    "delete-all": "pm2 delete all",
    "list": "pm2 list",
    "monit": "pm2 monit",
    "reload": "pm2 reload all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeverYu/rtsp2web.git"
  },
  "author": "Never Yu",
  "license": "ISC",
  "bugs": {
    "url": ""
  },
  "homepage": "https://github.com/NeverYu/rtsp2web#readme",
  "dependencies": {
    "base-64": "^1.0.0",
    "ws": "^8.5.0"
  }
}
